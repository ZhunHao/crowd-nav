[env]
time_limit = 100
time_step = 0.25
val_size = 100
test_size = 500
randomize_attributes = false


[reward]
success_reward = 1
collision_penalty = -0.25
discomfort_dist = 0.2
discomfort_penalty_factor = 0.5


[sim]
train_val_sim = circle_crossing
test_sim = circle_crossing
square_width = 10
circle_radius = 8
human_num = 3
static_obs = true
static_obs_num = 15
static_obs_shapes = rect


[humans]
visible = true
policy = orca
radius = 0.6
v_pref = 0.3
sensor = coordinates


[robot]
visible = false
policy = none
radius = 0.5
v_pref = 1
sensor = coordinates
init_x = -3
init_y = -3
goal_x = 5
goal_y = 5


[goal_allocator]
# WP-2: with init/goal ~11m apart, spacing > 2 m keeps the dynamic-obstacle
# corridor wide enough that humans don't pack onto the robot's path between
# consecutive waypoints. Tune per-phase with human_num_{train,val,test}.
num_waypoints = 4
min_inter_waypoint_dist = 2.0
max_tries = 500

[static_map]
enabled = true
margin = 0.5

[planner]
enabled = true
algorithm = theta_star
# Must exceed robot.radius (0.5) so Theta* vertices sit off the collision
# surface; reactive SARL drift otherwise triggers immediate static_collision.
inflation_radius = 1.0
grid_resolution = 0.25
bounds_xmin = -15.0
bounds_xmax = 15.0
bounds_ymin = -15.0
bounds_ymax = 15.0
goal_tolerance = 0.3
waypoint_simplify = true
