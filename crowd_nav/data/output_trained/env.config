[env]
time_limit = 100
time_step = 0.25
val_size = 100
test_size = 500
randomize_attributes = false


[reward]
success_reward = 1
collision_penalty = -0.25
discomfort_dist = 0.2
discomfort_penalty_factor = 0.5


[sim]
train_val_sim = circle_crossing
test_sim = circle_crossing
square_width = 10
circle_radius = 8
human_num = 3
static_obs = true
static_obs_num = 15
static_obs_shapes = rect


[humans]
visible = true
policy = orca
radius = 0.6
v_pref = 0.3
sensor = coordinates


[robot]
visible = false
policy = none
radius = 0.5
v_pref = 1
sensor = coordinates
init_x = -3
init_y = -3
goal_x = 5
goal_y = 5
